{
  "name": "@taucode/deterministic-compaction",
  "version": "0.1.0",
  "private": true,
  "description": "pi extension: send-time deterministic context compaction (seam A context hook + optional seam B session_before_compact), backed by @taucode/compaction-core. Loads into pi via --extension.",
  "type": "module",
  "keywords": [
    "pi-extension",
    "context-compaction",
    "coding-agent"
  ],
  "license": "MIT",
  "author": "lesPrivilege <lesprivilege@gmail.com>",
  "pi": {
    "extensions": [
      "src/extension.ts"
    ]
  },
  "main": "src/extension.ts",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@taucode/compaction-core": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": { "optional": true },
    "@earendil-works/pi-ai": { "optional": true },
    "@earendil-works/pi-coding-agent": { "optional": true },
    "@taucode/compaction-core": { "optional": true }
  }
}
