# Local dev symlink into pi's coding-agent node_modules (test runtime only).
# Recreate with:
#   ln -sfn ../../pi/packages/coding-agent/node_modules node_modules
node_modules

# Throwaway ambient-telemetry output written by the test suite (TAUCODE_AMBIENT_DIR
# in vitest.config.ts points here so tests never touch experiments/results/ambient).
.ambient-test-tmp/
