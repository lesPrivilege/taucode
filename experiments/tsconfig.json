{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2024"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": [],
    "paths": {
      "@taucode/compaction-core": ["../packages/compaction-core/src/index.ts"],
      "@earendil-works/pi-ai": ["../pi/packages/ai/src/index.ts"],
      "@earendil-works/pi-ai/compat": ["../pi/packages/ai/src/compat.ts"],
      "@earendil-works/pi-ai/oauth": ["../pi/packages/ai/src/oauth.ts"],
      "@earendil-works/pi-agent-core": ["../pi/packages/agent/src/index.ts"],
      "@earendil-works/pi-tui": ["../pi/packages/tui/src/index.ts"],
      "@earendil-works/pi-coding-agent": ["../pi/packages/coding-agent/src/index.ts"]
    }
  },
  "include": ["lib/**/*.ts", "fixtures/**/*.ts", "test/**/*.ts", "run.ts", "plan.ts", "compare.ts", "prepare-snapshot.ts", "export-review.ts"]
}
