{
  "name": "@taucode/experiments",
  "version": "0.1.0",
  "private": true,
  "description": "4-arm (A/B/C/D) compaction experiment harness for pi: plan/run/compare entry points over deterministic-compaction, mock fixtures, and real DeepSeek/OpenAI-compatible providers.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "plan": "node plan.ts",
    "run-arm": "node --import ./lib/register.mjs run.ts",
    "compare": "node --import ./lib/register.mjs compare.ts",
    "export-review": "node --experimental-transform-types export-review.ts"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@taucode/compaction-core": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": { "optional": true },
    "@earendil-works/pi-ai": { "optional": true },
    "@earendil-works/pi-coding-agent": { "optional": true },
    "@taucode/compaction-core": { "optional": true }
  }
}
